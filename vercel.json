{
  "version": 2,
  "routes": [
    { "src": "/api/auth/login",   "dest": "/api/auth/login.js"   },
    { "src": "/api/auth/logout",  "dest": "/api/auth/logout.js"  },
    { "src": "/api/devices",      "dest": "/api/devices.js"      },
    { "src": "/api/status",       "dest": "/api/status.js"       },
    { "src": "/api/save-reading", "dest": "/api/save-reading.js" },
    { "src": "/api/history",      "dest": "/api/history.js"      },
    { "src": "/api/cron-save",    "dest": "/api/cron-save.js"    },
    { "src": "/api/incidents",    "dest": "/api/incidents.js"    },
    { "src": "/api/gen-hash",     "dest": "/api/gen-hash.js"     },
    { "src": "/login",            "dest": "/login.html"          },
    { "src": "/login.html",       "dest": "/login.html"          },
    { "src": "/assets/(.*)",      "dest": "/assets/$1"           },
    { "src": "/(.*)\\.css",       "dest": "/$1.css"              },
    { "src": "/(.*)\\.js",        "dest": "/$1.js"               },
    { "src": "/(.*)\\.png",       "dest": "/$1.png"              },
    { "src": "/(.*)\\.svg",       "dest": "/$1.svg"              },
    { "src": "/(.*)\\.ico",       "dest": "/$1.ico"              },
    { "src": "/(.*)",             "dest": "/api/page.js"         }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff"                         },
        { "key": "X-Frame-Options",           "value": "DENY"                            },
        { "key": "X-XSS-Protection",          "value": "1; mode=block"                   },
