 "version": 2,
  "routes": [
    { "src": "/api/auth/login",   "dest": "/api/auth/login.js"   },
    { "src": "/api/auth/logout",  "dest": "/api/auth/logout.js"  },
    { "src": "/api/devices",      "dest": "/api/devices.js"      },
    { "src": "/api/status",       "dest": "/api/status.js"       },
    { "src": "/api/save-reading", "dest": "/api/save-reading.js" },
    { "src": "/api/history",      "dest": "/api/history.js"      },
    { "src": "/api/cron-save",    "dest": "/api/cron-save.js"    },
    { "src": "/api/incidents",    "dest": "/api/incidents.js"    },
    { "src": "/login",            "dest": "/login.html"          },
    { "src": "/(.*)",             "dest": "/index.html"          }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff"                                                         },
        { "key": "X-Frame-Options",           "value": "DENY"                                                            },
        { "key": "X-XSS-Protection",          "value": "1; mode=block"                                                   },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin"                                 },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()"                        },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload"                    },
        { "key": "Content-Security-Policy",   "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob:; connect-src 'self'; font-src 'self' https://cdn.jsdelivr.net; frame-ancestors 'none'" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron-save", "schedule": "*/5 * * * *" }
  ]
}
